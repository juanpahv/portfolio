---
import { getTranslations } from "@/i18n/ui";
import AnthropicIcon from "../icons/AnthropicIcon.astro";
import AstroIcon from "../icons/AstroIcon.astro";
import AWSIcon from "../icons/AWSIcon.astro";
import BashIcon from "../icons/BashIcon.astro";
import DockerIcon from "../icons/DockerIcon.astro";
import ExpressIcon from "../icons/ExpressIcon.astro";
import GeminiIcon from "../icons/GeminiIcon.astro";
import GitIcon from "../icons/GitIcon.astro";
import GoogleCloudIcon from "../icons/GoogleCloudIcon.astro";
import JavaIcon from "../icons/JavaIcon.astro";
import JavascriptIcon from "../icons/JavascriptIcon.astro";
import NodejsIcon from "../icons/NodejsIcon.astro";
import PostgreSQLIcon from "../icons/PostgreSQLIcon.astro";
import PythonIcon from "../icons/PythonIcon.astro";
import ReactIcon from "../icons/ReactIcon.astro";
import TypescriptIcon from "../icons/TypescriptIcon.astro";
import SkillCard from "./SkillCard.astro";

const t = getTranslations(Astro.currentLocale);
const languages = [
  {
    name: "JavaScript",
    icon: JavascriptIcon,
  },
  {
    name: "TypeScript",
    icon: TypescriptIcon,
  },
  {
    name: "Java",
    icon: JavaIcon,
  },
  {
    name: "Python",
    icon: PythonIcon,
  },
];

const frameworks = [
  {
    name: "React",
    icon: ReactIcon,
  },
  {
    name: "Express.js",
    icon: ExpressIcon,
  },
  {
    name: "Astro",
    icon: AstroIcon,
  },
];

const software = [
  {
    name: "Node.js",
    icon: NodejsIcon,
  },
  {
    name: "Bash",
    icon: BashIcon,
  },
  {
    name: "Docker",
    icon: DockerIcon,
  },
  {
    name: "PostgreSQL",
    icon: PostgreSQLIcon,
  },
];

const cloud = [
  {
    name: "Google Cloud",
    icon: GoogleCloudIcon,
  },
  {
    name: "AWS",
    icon: AWSIcon,
  },
];

const ai = [
  {
    name: "Vertex AI / Gemini",
    icon: GeminiIcon,
  },
  {
    name: "Claude",
    icon: AnthropicIcon,
  },
];
---

<SkillCard title={t("skills.languages")}>
  {
    languages.map((language) => (
      <span class="text-lg flex flex-col items-center gap-6 pb-6">
        <language.icon class="size-8" />
        {language.name}
      </span>
    ))
  }
</SkillCard>

<SkillCard title={t("skills.frameworks")}>
  {
    frameworks.map((framework) => (
      <span class="text-lg flex flex-col items-center gap-6 pb-6">
        <framework.icon class="size-8" />
        {framework.name}
      </span>
    ))
  }
</SkillCard>

<SkillCard title={t("skills.cloud")}>
  {
    cloud.map((item) => (
      <span class="text-lg flex flex-col items-center gap-6 pb-6">
        <item.icon class="size-8" />
        {item.name}
      </span>
    ))
  }
</SkillCard>

<SkillCard title={t("skills.ai")}>
  {
    ai.map((item) => (
      <span class="text-lg flex flex-col items-center gap-6 pb-6">
        <item.icon class="size-8" />
        {item.name}
      </span>
    ))
  }
</SkillCard>

<SkillCard title={t("skills.software")}>
  {
    software.map((software) => (
      <span class="text-lg flex flex-col items-center gap-6 pb-6">
        <software.icon class="size-8" />
        {software.name}
      </span>
    ))
  }
</SkillCard>
