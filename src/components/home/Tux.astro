---
import { getTranslations } from "@/i18n/ui";

const t = getTranslations(Astro.currentLocale);
const bio = t("about.bio");
const highlight = t("about.bioHighlight");
const [before, after] = bio.split(highlight);
---

<button
  type="button"
  popovertarget="tux-bio"
  class="tux"
  aria-label={t("about.title")}
>
  <img
    src="/images/tux.png"
    alt=""
    width="106"
    height="126"
    draggable="false"
  />
</button>

<div id="tux-bio" popover class="bubble">
  <p class="text-base text-pretty">
    {before}<strong>{highlight}</strong>{after}
  </p>
</div>

<style>
  .tux {
    position: fixed;
    left: 0;
    bottom: 1.5rem;
    z-index: 999;
    /* ponytail: -40% not -50%, the PNG has transparent padding the old inline SVG lacked */
    transform: translateX(-40%);
    transition: transform 300ms ease;
    cursor: pointer;
    filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.4));
  }

  .tux:hover,
  .tux:focus-visible {
    transform: translateX(-8%);
  }

  .bubble {
    position: fixed;
    left: 4.5rem;
    bottom: 6rem;
    top: auto;
    right: auto;
    margin: 0;
    max-width: min(24rem, calc(100vw - 6rem));
    padding: 1rem 1.25rem;
    color: #fdfdfd;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 16px;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    overflow: visible;
  }

  .bubble:popover-open {
    opacity: 1;
    translate: 0 0;
  }

  .bubble {
    opacity: 0;
    translate: -8px 8px;
    transition:
      opacity 200ms ease,
      translate 200ms ease,
      display 200ms allow-discrete,
      overlay 200ms allow-discrete;
  }

  @starting-style {
    .bubble:popover-open {
      opacity: 0;
      translate: -8px 8px;
    }
  }

  @media (max-width: 640px) {
    .bubble {
      left: 1rem;
      right: 1rem;
      max-width: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tux,
    .bubble {
      transition: none;
    }
  }
</style>
