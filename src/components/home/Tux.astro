---
import { getTranslations } from "@/i18n/ui";

const t = getTranslations(Astro.currentLocale);
const bio = t("about.bio");
---

<button
  type="button"
  popovertarget="tux-bio"
  class="tux"
  aria-label={t("about.title")}
>
  <img
    src="/images/tux.png"
    alt=""
    width="106"
    height="126"
    draggable="false"
  />
</button>

<div id="tux-bio" popover class="bubble">
  <p class="text-base text-pretty">
    {bio}
  </p>
</div>

<style>
  .tux {
    position: fixed;
    left: 0.75rem;
    bottom: 0;
    z-index: 999;
    /* ponytail: sunk below the fold so only the head shows; hover lifts him */
    transform: translateY(58%);
    transition: transform 300ms ease;
    cursor: pointer;
    filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.4));
  }

  .tux:hover,
  .tux:focus-visible {
    transform: translateY(12%);
  }

  .tux img {
    display: block;
    width: clamp(56px, 8vw, 106px);
    height: auto;
  }

  .bubble {
    position: fixed;
    left: 5.5rem;
    bottom: 2rem;
    top: auto;
    right: auto;
    margin: 0;
    max-width: min(24rem, calc(100vw - 6rem));
    padding: 1rem 1.25rem;
    color: #fdfdfd;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 16px;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    overflow: visible;
  }

  .bubble:popover-open {
    opacity: 1;
    translate: 0 0;
  }

  .bubble {
    opacity: 0;
    translate: -8px 8px;
    transition:
      opacity 200ms ease,
      translate 200ms ease,
      display 200ms allow-discrete,
      overlay 200ms allow-discrete;
  }

  @starting-style {
    .bubble:popover-open {
      opacity: 0;
      translate: -8px 8px;
    }
  }

  /* No hover on touch: the sink-and-lift trick can never resolve, and mobile
     browser chrome overlays the sunk strip. Sit him fully above the safe area. */
  @media (hover: none) {
    .tux {
      bottom: calc(0.5rem + env(safe-area-inset-bottom, 0px));
      transform: none;
    }

    .tux:hover,
    .tux:focus-visible {
      transform: none;
    }
  }

  @media (max-width: 640px) {
    .bubble {
      left: 1rem;
      right: 1rem;
      bottom: calc(6rem + env(safe-area-inset-bottom, 0px));
      max-width: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tux,
    .bubble {
      transition: none;
    }
  }
</style>
