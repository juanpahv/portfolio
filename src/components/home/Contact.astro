---
import { getTranslations } from "@/i18n/ui";
import Pill from "./Pill.astro";

const t = getTranslations(Astro.currentLocale);
const email = "juanpahv@juanpahv.com";
---

<p class="text-lg opacity-70 text-center text-pretty">{t("contact.intro")}</p>

<div class="flex flex-wrap justify-center items-center gap-4">
  <Pill href={`mailto:${email}`} target="_self">{email}</Pill>
  <button
    type="button"
    id="copy-email"
    data-email={email}
    data-label-copy={t("contact.copy")}
    data-label-copied={t("contact.copied")}
    hidden
    class="rounded-full border border-white/10 bg-white/5 flex justify-center items-center gap-x-2 py-2 px-4 hover:scale-110 hover:bg-white/10 transition"
  >
    {t("contact.copy")}
  </button>
</div>
<p id="copy-status" class="sr-only" aria-live="polite"></p>

<script>
  const button = document.querySelector<HTMLButtonElement>("#copy-email");
  const status = document.querySelector<HTMLParagraphElement>("#copy-status");

  // ponytail: clipboard needs a secure context, so the button stays hidden
  // unless it can actually work. The mailto link is always there regardless.
  if (button && navigator.clipboard) {
    button.hidden = false;

    const { email, labelCopy, labelCopied } = button.dataset as Record<
      string,
      string
    >;
    let timer: ReturnType<typeof setTimeout>;

    button.addEventListener("click", async () => {
      await navigator.clipboard.writeText(email);
      button.textContent = labelCopied;
      if (status) status.textContent = labelCopied;
      clearTimeout(timer);
      timer = setTimeout(() => {
        button.textContent = labelCopy;
      }, 2000);
    });
  }
</script>
