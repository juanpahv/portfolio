---
import { getTranslations } from "@/i18n/ui";

const t = getTranslations(Astro.currentLocale);
const bio = t("about.bio");
const highlight = t("about.bioHighlight");
// ponytail: single highlighted phrase per locale; if copy needs richer markup, move the bio to a content collection
const [before, after] = bio.split(highlight);
---

<article>
  <p class="text-xl text-pretty">
    {before}<strong>{highlight}</strong>{after}
  </p>
</article>
